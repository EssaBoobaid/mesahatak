<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/review.css">
</head>
<body class="review-page">
  <%- include('../partials/navbar', { lang: 'ar', active: 'reviews', user: typeof user !== 'undefined' ? user : null }) %>
  <main class="reviews-shell">
    <section class="page-hero card">
      <div>
        <p class="eyebrow">التقييمات</p>
        <h1>آراء المستخدمين</h1>
        <p class="muted">اطلع على آخر التعليقات والتقييمات وشارك رأيك حول المساحة التي استأجرتها.</p>
      </div>
      <% if (typeof user !== 'undefined' && user) { %>
        <a class="btn primary" href="#add-review">أضف تقييمك</a>
      <% } %>
    </section>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="alert"><i class="fa-solid fa-triangle-exclamation"></i><%= errorMessage %></div>
    <% } %>

    <div class="grid">
      <section class="card form-card" id="add-review">
        <div class="card-header">
          <div>
            <p class="eyebrow">أرسل تقييمك</p>
            <h2>ما رأيك في المؤجر؟</h2>
            <p class="muted">اختر التقييم وأضف ملاحظة قصيرة.</p>
          </div>
        </div>

        <% if (typeof user !== 'undefined' && user) { %>
          <form class="review-form" action="/reviews" method="POST">
            <input type="hidden" name="booking_id" value="<%= bookingId || '' %>">
            <input type="hidden" name="space_id" value="<%= spaceId || '' %>">

            <div class="field">
              <label>التقييم</label>
              <div class="star-rating" dir="ltr">
                <% for (let i = 5; i >= 1; i--) { %>
                  <input type="radio" id="star-<%= i %>" name="rating" value="<%= i %>" required>
                  <label for="star-<%= i %>" title="<%= i %> نجوم"></label>
                <% } %>
              </div>
            </div>

            <div class="field">
              <label>ملاحظات (اختياري)</label>
              <textarea name="comment" rows="4" placeholder="اكتب ملاحظتك"></textarea>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn primary">حفظ التقييم</button>
              <% if (!bookingId || !spaceId) { %>
                <span class="muted">انتقل من صفحة حجوزاتي لاختيار حجز للتقييم.</span>
              <% } %>
            </div>
          </form>
        <% } else { %>
          <div class="alert">الرجاء تسجيل الدخول لإضافة تقييم.</div>
        <% } %>
      </section>

      <section class="card list-card">
        <div class="card-header">
          <div>
            <p class="eyebrow">آخر التقييمات</p>
            <h2>ما يقوله الآخرون</h2>
          </div>
        </div>

        <div class="review-list">
          <% if (reviews && reviews.length) { %>
            <% reviews.forEach(r => { %>
              <article class="review-item">
                <div class="review-head">
                  <div class="avatar">
                    <i class="fa-solid fa-user"></i>
                  </div>
                  <div class="meta">
                    <strong><%= r.User ? r.User.full_name : 'مستخدم' %></strong>
                    <p class="muted">المساحة: <%= r.Space ? r.Space.name : '' %></p>
                  </div>
                  <div class="rating-badge">
                    <span><%= r.rating || 0 %>/5</span>
                    <div class="stars">
                      <% for (let i = 0; i < (r.rating || 0); i++) { %><i class="fa-solid fa-star"></i><% } %>
                    </div>
                  </div>
                </div>
                <p class="review-body"><%= r.comment || 'بدون تعليق' %></p>
              </article>
            <% }) %>
          <% } else { %>
            <p class="muted">لا توجد تقييمات بعد.</p>
          <% } %>
        </div>
      </section>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
